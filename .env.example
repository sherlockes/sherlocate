# Example environment configuration for Sherlocate
# Copy this file to '.env' and edit the values.

# Whitelist of allowed tracking devices and their optional passwords
# Format: device_id:password,device_id_without_password,...
ALLOWED_DEVICES=123456:pwd1,789012:pwd2,345678

# Timezone (for internal logging)
TZ=Europe/Madrid

# Port
PORT=8000
